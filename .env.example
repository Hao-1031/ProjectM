# Project-M 2.0 环境变量示例
# 复制为 .env.local 后按需填写

# 应用基础
NODE_ENV=production
PORT=3000
HOSTNAME=0.0.0.0
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase 后端（排行榜、公告）
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# 服务端专用，仅用于飞书 OAuth 桥接创建用户，勿暴露到前端
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# 管理员后台密钥（用于 /admin 公告管理）
ADMIN_KEY=your-secure-random-key

# Supabase Auth OAuth 回调地址需要在 Supabase Dashboard 中配置为：
# http://localhost:3000/api/auth/callback （开发）
# https://your-domain.com/api/auth/callback （生产）

# 飞书/Lark 自建应用 OAuth（可选）
LARK_APP_ID=your-lark-app-id
LARK_APP_SECRET=your-lark-app-secret
LARK_OAUTH_SECRET=your-random-hmac-secret-for-bridge
# 飞书回调地址需配置为：https://your-domain.com/api/auth/lark/callback

# Sentry 错误监控（可选）
# 未配置 SENTRY_AUTH_TOKEN 时，构建会自动跳过 sourcemap 上传，不影响运行
SENTRY_ORG=your-org
SENTRY_PROJECT=project-m
SENTRY_AUTH_TOKEN=your-token
NEXT_PUBLIC_SENTRY_DSN=https://xxx@yyy.ingest.sentry.io/zzz
