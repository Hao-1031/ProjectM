# Project-M 环境变量示例
# 复制本文件为 .env.local 后按需填写
# 标注 [必填] 的变量缺失会导致构建或运行失败；[可选] 可不填

# ============================================================
# 应用基础 [必填]
# ============================================================
NODE_ENV=production
PORT=3000
HOSTNAME=0.0.0.0
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ============================================================
# Supabase 后端 [必填]
# 来源：Supabase Dashboard > Project Settings > API
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# 服务端专用，用于飞书 OAuth 桥接创建用户等管理操作，切勿暴露到前端
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================================
# 管理员后台 [必填]
# 用于 /admin 公告管理接口的 Bearer Token 校验
# ============================================================
ADMIN_KEY=your-secure-random-key

# ============================================================
# Supabase Auth OAuth 回调地址配置
# 需要在 Supabase Dashboard > Authentication > URL Configuration 中填写：
#   Site URL: http://localhost:3000 （开发）或 https://your-domain.com （生产）
#   Redirect URL: http://localhost:3000/api/auth/callback （开发）
#                  https://your-domain.com/api/auth/callback （生产）
# ============================================================

# ============================================================
# 飞书 / Lark 自建应用 OAuth [可选]
# 若不需要飞书登录，可留空；相关接口会优雅降级
# ============================================================
LARK_APP_ID=your-lark-app-id
LARK_APP_SECRET=your-lark-app-secret
# 用于加密飞书 OAuth state 的 HMAC 密钥，长度建议 >= 32
LARK_OAUTH_SECRET=your-random-hmac-secret-for-bridge
# 飞书回调地址需配置为：https://your-domain.com/api/auth/lark/callback

# ============================================================
# Sentry 错误监控 [可选]
# 未配置 SENTRY_AUTH_TOKEN 时，next.config.mjs 会自动跳过 sourcemap 上传
# ============================================================
SENTRY_ORG=your-org
SENTRY_PROJECT=project-m
SENTRY_AUTH_TOKEN=your-token
NEXT_PUBLIC_SENTRY_DSN=https://xxx@yyy.ingest.sentry.io/zzz
